# Core model configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Persona configuration
BOT_NAME=Site Assistant
BOT_ROLE=an AI assistant for a personal website
BOT_OBJECTIVE=Help visitors understand the site owner's background, projects, interests, and ways to get in touch.
BOT_TONE=professional, warm, and concise
BOT_CALL_TO_ACTION=When it fits naturally, encourage visitors to explore the site or use the contact details provided in the knowledge base.
BOT_ADDITIONAL_INSTRUCTIONS=

# Knowledge loading
KNOWLEDGE_DIR=knowledge

# API configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Session management
SESSION_TIMEOUT_MINUTES=30
MAX_HISTORY_LENGTH=20

# Rate limiting
RATE_LIMIT=20
